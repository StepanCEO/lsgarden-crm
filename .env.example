DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret
DJANGO_DEBUG=0
CRM_AUTO_SEED_DEMO=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_SECURE_SSL_REDIRECT=0
POSTGRES_DB=plant_crm
POSTGRES_USER=plant_crm
POSTGRES_PASSWORD=plant_crm
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_CONN_MAX_AGE=60

# Yandex Object Storage (S3)
AWS_ACCESS_KEY_ID=your-yandex-access-key
AWS_SECRET_ACCESS_KEY=your-yandex-secret-key
AWS_STORAGE_BUCKET_NAME=crm-lsg
AWS_S3_ENDPOINT_URL=https://storage.yandexcloud.net
AWS_S3_REGION_NAME=ru-central1
MEDIA_URL=https://crm-lsg.storage.yandexcloud.net/

# Avito
AVITO_EMAIL_HOST=imap.yandex.ru
AVITO_EMAIL_PORT=993
AVITO_EMAIL_USER=avito@example.com
AVITO_EMAIL_PASSWORD=your-app-password
AVITO_USERNAME=
AVITO_PASSWORD=
AVITO_AUTH_FILE=avito_auth.json
AVITO_COOKIES_FILE=avito_cookies.json
AVITO_POLL_LIMIT=20

# Email (SMTP для кодов входа)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.com
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USE_TLS=0
EMAIL_HOST_USER=your-email@yandex.ru
EMAIL_HOST_PASSWORD=your-app-password-or-empty
EMAIL_OAUTH_TOKEN=
DEFAULT_FROM_EMAIL=your-email@yandex.ru

# Telegram
TG_INTEGRATION_MODE=bot
TG_BOT_TOKEN=your-telegram-bot-token
TG_GROUP_ID=your-chat-id
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=telegram_account
TG_DIALOG_LIMIT=50
TG_HISTORY_LIMIT=40

# VK API
VK_API_TOKEN=your-vk-api-token
VK_GROUP_ID=your-group-id

# Website forms webhook
SITE_WEBHOOK_TOKEN=replace-with-a-long-random-token

# 1C nomenclature import
ONE_C_NOMENCLATURE_PATH=/app/data/1c_nomenclature.xlsx

# Shop (WooCommerce) admin sync (Playwright)
SHOP_ADMIN_URL=https://shop.lsgarden.ru
SHOP_ADMIN_USERNAME=
SHOP_ADMIN_PASSWORD=
